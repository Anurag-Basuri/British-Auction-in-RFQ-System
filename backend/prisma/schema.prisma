// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role     @default(SUPPLIER)
  rfqs      Rfq[]    @relation("BuyerRfqs")
  bids      Bid[]    @relation("SupplierBids")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  BUYER
  SUPPLIER
}

model Rfq {
  id                  Int      @id @default(autoincrement())
  title               String
  description         String?
  start_time          DateTime
  close_time          DateTime
  forced_close_time   DateTime
  pickup_date         DateTime?
  trigger_window_mins Int      // X minutes before close to trigger extension
  extension_mins      Int      // Y minutes to extend if triggered
  trigger_type        TriggerType
  status              RfqStatus @default(DRAFT)
  buyerId             Int
  buyer               User      @relation("BuyerRfqs", fields: [buyerId], references: [id])
  bids                Bid[]
  extensionLogs       ExtensionLog[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

enum TriggerType {
  ANY_BID
  RANK_CHANGE
  L1_CHANGE
}

enum RfqStatus {
  DRAFT
  ACTIVE
  CLOSED
}

model Bid {
  id                  Int      @id @default(autoincrement())
  rfqId               Int
  rfq                 Rfq      @relation(fields: [rfqId], references: [id])
  supplierId          Int
  supplier            User     @relation("SupplierBids", fields: [supplierId], references: [id])
  
  // Detailed Quote Submission Breakdown
  freight_charges     Float
  origin_charges      Float
  destination_charges Float
  price               Float    // Total cost (freight + origin + destination)
  
  transit_time        String   // e.g. "14 Days"
  quote_validity      DateTime
  
  timestamp           DateTime @default(now())
  
  triggeringExtensions ExtensionLog[]
  
  @@index([rfqId, price(sort: Asc), timestamp(sort: Asc)])
}

model ExtensionLog {
  id              Int      @id @default(autoincrement())
  rfqId           Int
  rfq             Rfq      @relation(fields: [rfqId], references: [id])
  
  // The bid that triggered the event (nullable just in case)
  triggerBidId    Int?     
  triggerBid      Bid?     @relation(fields: [triggerBidId], references: [id])
  
  reason          String   // e.g. "Extended by Y mins due to Supplier Rank Change"
  extended_mins   Int      // Amount of minutes added
  previous_close  DateTime // What the close time was *before* this extension
  new_close       DateTime // What it was updated to become
  
  createdAt       DateTime @default(now())
}
